# ---------------------------------------------------------------
# RNN Sentiment project specific ignores
# (Repo-root .gitignore already covers Python/venv/IDE/OS clutter.)
# ---------------------------------------------------------------

# Pre-trained word embeddings (large, downloadable)
data/glove/
data/word2vec/
*.zip

# Processed / tokenised data caches (regenerated by preprocessing)
data/processed/
data/raw/
*.pkl
*.npy

# Trained model checkpoints & training history dumps (large binaries)
outputs/checkpoints/
*.pt
*.pth
*.ckpt

# Local-only run artefacts
*.tmp
*.lock

# NOTE: outputs/logs/ (plots, JSON summaries, classification reports)
# is intentionally tracked because it is referenced by the report.
