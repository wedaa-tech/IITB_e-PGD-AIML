# ---------------------------------------------------------------
# CIFAR-100 project specific ignores
# (Repo-root .gitignore already covers Python/venv/IDE/OS clutter.)
# ---------------------------------------------------------------

# Raw dataset (downloadable / regeneratable)
data/cifar-100-python/
data/cifar-100-python.tar.gz
data/*.tar.gz
data/*.zip

# Cached feature tensors (regenerated by the VGG extractor pipeline)
data/vgg_feature_cache/
*.npy

# Trained model checkpoints (large binaries)
outputs/checkpoints/
*.pth
*.pt
*.ckpt

# Local-only run artefacts
*.tmp
*.lock

# NOTE: outputs/plots/ and outputs/results/ are intentionally tracked
# because they are referenced by report.md / assignment_answers.md.
