# ---------------------------------------------------------------
# Repository-wide ignores (apply to every sub-project)
# ---------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Python byte-code / build artefacts
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
build/
dist/
.eggs/
pip-wheel-metadata/

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Jupyter / IPython
.ipynb_checkpoints/
*.ipynb_checkpoints

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs & temp
*.log
*.tmp
*.bak

# Test / coverage
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Environment files (may contain secrets)
.env
.env.*
!.env.example
